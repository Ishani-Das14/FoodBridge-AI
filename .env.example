# ==============================================================================
# FoodBridge AI - Environment Variables Template
# Copy this file to .env and configure the values for your local development setup.
# ==============================================================================

# ------------------------------------------------------------------------------
# General Application Settings
# ------------------------------------------------------------------------------
PROJECT_NAME="FoodBridge AI"
ENVIRONMENT=development # development, staging, production
SECRET_KEY=supersecretjwtkeythatshouldbechangedinproduction123! # Generate with: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# CORS settings: comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ------------------------------------------------------------------------------
# PostgreSQL + PostGIS Database Settings
# ------------------------------------------------------------------------------
# Set to 'db' if running inside docker-compose, or 'localhost' if running FastAPI locally
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=foodbridge_admin
POSTGRES_PASSWORD=foodbridge_secure_pass_99
POSTGRES_DB=foodbridge_db

# ------------------------------------------------------------------------------
# Redis Settings (used for Caching & Celery Broker)
# ------------------------------------------------------------------------------
# Set to 'redis' if running inside docker-compose, or 'localhost' if running locally
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ------------------------------------------------------------------------------
# Celery Task Queue Settings
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ------------------------------------------------------------------------------
# AWS S3 Storage Settings (for food images, NGO certificates, receipts)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET_NAME=foodbridge-ai-storage

# ------------------------------------------------------------------------------
# Machine Learning & Optimization Engine Settings
# ------------------------------------------------------------------------------
# Paths to pre-trained ML models (surplus prediction, expiry estimations)
MODEL_REGISTRY_PATH=/app/ml_models
# Time limit (seconds) for OR-Tools volunteer vehicle routing optimization solver
ROUTING_SOLVER_TIME_LIMIT_SECS=30

# ------------------------------------------------------------------------------
# Third-Party API Credentials
# ------------------------------------------------------------------------------
# Mapbox/Google Maps for geocoding address coordination and delivery route plotting
MAPBOX_ACCESS_TOKEN=your_mapbox_public_token
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ------------------------------------------------------------------------------
# React Frontend Settings (Vite style)
# ------------------------------------------------------------------------------
# Accessible inside React through import.meta.env.VITE_API_URL
VITE_API_URL=http://localhost:8000/api/v1
VITE_MAPBOX_TOKEN=your_mapbox_public_token
