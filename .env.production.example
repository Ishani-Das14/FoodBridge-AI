# ==========================================
# FoodBridge AI - Production Environment Template
# DO NOT COMMIT ACTUAL SECRETS TO VERSION CONTROL
# ==========================================

# 1. Database & Cache
DB_URL=postgresql://user:password@postgresql:5432/foodbridge_db
REDIS_URL=redis://redis:6379/0

# 2. Celery Configurations
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# 3. Security (JWT Authentication)
JWT_SECRET=generate_a_secure_random_string_here_for_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 4. Third-Party Integrations
# AWS (For S3 Certificates & Logs)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=foodbridge-certificates-prod

# SendGrid (Email Notifications)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Google Maps (For Distance Matrix & VRP Solver)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 5. Web Push Notifications (VAPID Keys)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_CLAIM_EMAIL=admin@foodbridge.ai

# 6. API Environment Configurations
ENVIRONMENT=production
DEBUG=False
CORS_ORIGINS=https://foodbridge.ai,https://admin.foodbridge.ai
